# Copy this to .env and set at least one API key

# Provider keys — set whichever you have
OPENAI_API_KEY=sk-proj-...
TOGETHERAI_API_KEY=tgp_v1_...
OPENROUTER_API_KEY=sk-or-v1-...

# Model to use — must match the provider key you set above
# OpenAI:      openai/gpt-4o
# Together AI: together_ai/meta-llama/Llama-3.3-70B-Instruct-Turbo
# OpenRouter:  openrouter/openai/gpt-4o
MODEL=openai/gpt-4o

# Optional
MAX_WORKERS=4
PAPERS_DIR=papers
REVIEWS_DIR=reviews
